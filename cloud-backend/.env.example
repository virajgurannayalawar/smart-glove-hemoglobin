PROJECT_NAME="Smart Glove Backend"
API_V1_STR="/api/v1"

# Security (change in production)
SECRET_KEY="change-me"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES="10080"

# AES encryption key (32 bytes recommended)
AES_SECRET_KEY="32byte-long-secret-key-for-aes-!"

# Mongo
MONGODB_URL="mongodb://localhost:27017"
DATABASE_NAME="smart_glove"

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Model (backend-side prediction)
MODEL_PROVIDER="mock"
MOCK_HEMOGLOBIN_VALUE="13.2"

# Image processing (pre-model)
IMAGE_PROCESSING_ENABLED="true"
MODEL_IMAGE_SIZE="224"

# Observability
LOG_LEVEL="INFO"

# CORS (set explicit origins in production)
# Example: CORS_ALLOW_ORIGINS='["https://your-app.com","http://localhost:5173"]'
CORS_ALLOW_ORIGINS='["*"]'
CORS_ALLOW_METHODS='["*"]'
CORS_ALLOW_HEADERS='["*"]'
