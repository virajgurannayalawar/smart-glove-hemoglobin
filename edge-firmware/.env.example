# Smart Glove Edge Firmware Configuration
# Copy this file to .env and fill in your values

# ============================================
# Backend Configuration
# ============================================
BACKEND_BASE_URL=https://api.smartglovecloud.com
API_PREFIX=/api/v1

# ============================================
# Provisioning Credentials (set during BLE provisioning)
# ============================================
OWNER_ID=your_owner_id_here
GLOVE_API_KEY=your_glove_api_key_here

# ============================================
# Camera Configuration
# ============================================
# Camera index (0 for /dev/video0, 1 for /dev/video1, etc.)
CAMERA_INDEX=0
# Resolution (width x height)
CAMERA_RESOLUTION=1024x1024
# Image format (jpeg, png)
CAMERA_FORMAT=jpeg
# Camera warm-up time in milliseconds
CAMERA_WARMUP_MS=300

# ============================================
# Network Configuration
# ============================================
# Server host (0.0.0.0 to listen on all interfaces)
SERVER_HOST=0.0.0.0
# Server port
SERVER_PORT=8000
# mDNS hostname base (will be advertised as glove-<OWNER_ID>.local)
MDNS_HOSTNAME=glove

# ============================================
# Power Management (GPIO)
# ============================================
# Enable GPIO-based power control for camera and LEDs
ENABLE_GPIO_POWER_CONTROL=false
# GPIO pin for camera power control (BCM numbering)
GPIO_CAMERA_POWER_PIN=17
# GPIO pin for LED power control (BCM numbering)
GPIO_LED_POWER_PIN=18

# ============================================
# Cache Configuration
# ============================================
# Directory for offline cache queue
CACHE_DIR=/var/lib/smart_glove/queue
# Maximum cache size in MB
MAX_CACHE_SIZE_MB=100
# Maximum retry attempts for failed uploads
RETRY_MAX_ATTEMPTS=5
# Base backoff time in seconds (exponential backoff)
RETRY_BACKOFF_SECONDS=30

# ============================================
# Encryption Configuration
# ============================================
# AES-256 secret key (MUST match backend exactly - 32 bytes)
# DO NOT change this unless backend is also updated
AES_SECRET_KEY=32byte-long-secret-key-for-aes-!

# ============================================
# Logging Configuration
# ============================================
# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
# Log format (json, text)
LOG_FORMAT=json
